{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": { "maxDuration": 60 }
    },
    {
      "src": "zapauto.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "zapauto.html"
    }
  ],
  "env": {
    "EVOLUTION_BASE": "@evolution_base",
    "EVOLUTION_INSTANCE": "@evolution_instance",
    "EVOLUTION_KEY": "@evolution_key",
    "BOT_NOME": "MRP Bot",
    "BOT_VERSION": "1.0.0",
    "NODE_ENV": "production"
  }
}
